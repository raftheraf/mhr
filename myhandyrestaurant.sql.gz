--
-- Struttura della tabella `mhr_conf_en`
--

CREATE TABLE IF NOT EXISTS `mhr_conf_en` (
  `id` int(11) NOT NULL auto_increment,
  `table_id` int(11) NOT NULL default '0',
  `table_name` text NOT NULL,
  PRIMARY KEY  (`id`)
) ENGINE=MyISAM  DEFAULT CHARSET=latin1 AUTO_INCREMENT=45 ;

--
-- Dump dei dati per la tabella `mhr_conf_en`
--

INSERT INTO `mhr_conf_en` (`id`, `table_id`, `table_name`) VALUES
(1, 1, '&lt;b&gt;Ingredients per page.&lt;/b&gt;&lt;br/&gt;Sets the maximum number of ingredients showed on a single page in the modification page. Beyond this value the alphabetical list will be used.'),
(4, 4, '&lt;b&gt;Number of dishes to be showed in the top list.&lt;/b&gt;&lt;br/&gt;Eg.: 3 -&gt; the 3 most requested dishes are showed. (0 to disable top list display)'),
(5, 5, '&lt;b&gt;Show the modifications in the last modified summary line.&lt;/b&gt;&lt;br/&gt;If active, shows all the modifications associated to an order in the summary line.'),
(6, 6, '&lt;b&gt;Closing time.&lt;/b&gt;&lt;br/&gt;Used to decide when to close the accounting day. To be given in the following format: HHMMSS (Hours, minutes, seconds) without spaces and padded with zeros. Eg: if the place closes and 3:30 in the morning, you should write 033000. Use 24 hours format.'),
(7, 7, '&lt;b&gt;Printing system.&lt;/b&gt;&lt;br/&gt;The available printing systems are:&lt;br/&gt;lp or cupsys: for linux/unix systems&lt;br/&gt;win: for MS-Windows sytems (not tested)'),
(8, 8, '&lt;b&gt;Automatic association.&lt;/b&gt;&lt;br/&gt;If active, the waiter is not asked whether to associate the table or not, but the association is always done automatically.'),
(9, 9, '&lt;b&gt;Allow disassociation.&lt;/b&gt;&lt;br/&gt;If active, the cashier can disassociate a table from a waiter.'),
(10, 10, '&lt;b&gt;Autocalc considers removed ingredients.&lt;/b&gt;&lt;br/&gt;If active, the automatic price calculator (based on added ingredients number) calculates a removed ingredient as a &quot;-1&quot;, otherwise it just ignores them.'),
(12, 12, '&lt;b&gt;Global refresh time.&lt;/b&gt;&lt;br/&gt;Sets the time in seconds before ok messages disappear automatically in any zone except the waiters&#039; one. Error messages never disappear automatically.'),
(13, 13, '&lt;b&gt;Header repeater.&lt;/b&gt;&lt;br/&gt;Sets after how many lines the header row should be repeated in the accounting zone.'),
(15, 15, '&lt;b&gt;Table locking time.&lt;/b&gt;&lt;br/&gt;Time in seconds that has to be between the operation of different waiters on the same table. If set to 0, the lock is disabled.'),
(16, 16, '&lt;b&gt;Default language.&lt;/b&gt;&lt;br/&gt;Language used in the whole system, where not otherwise specified (for example in the waiters&#039; zone, where the language of the individual waiter is most prioritary).'),
(17, 17, '&lt;b&gt;Software vendor name.&lt;/b&gt;&lt;br/&gt;Used in error messages only, to give support address.'),
(18, 18, '&lt;b&gt;Software vendor email address.&lt;/b&gt;&lt;br/&gt;Used in error messages only, to give support address.'),
(19, 19, '&lt;b&gt;Default quantity.&lt;/b&gt;&lt;br/&gt;Quantity used by default when taking a new order.'),
(21, 21, '&lt;b&gt;Always print remaining tickets.&lt;/b&gt;&lt;br/&gt;If active, prints all the not-yet-printed order tickets when closing a table.'),
(22, 22, '&lt;b&gt;Always print remaining tickets in takeaway.&lt;/b&gt;&lt;br/&gt;If active, prints all the not-yet-printed order tickets when closing a takeaway table.'),
(25, 25, '&lt;b&gt;Automatic refresh on tables list page.&lt;/b&gt;&lt;br/&gt;Sets how many seconds to wait before reloading the tables list page. (0 to disable)'),
(26, 26, '&lt;b&gt;Automatic routing to the tables list.&lt;/b&gt;&lt;br/&gt;Sets how many seconds of inactivity to wait, before loading the tables list page. (0 to disable)'),
(30, 30, '&lt;b&gt;Show invisible dishes/ingredients.&lt;/b&gt;&lt;br/&gt;If active, also invisible ingredients and dishes will be displayed in the waiter zone .'),
(28, 28, '&lt;b&gt;Service fee - Price&lt;/b&gt;&lt;br /&gt;Amount of the Service fee charge per person. You can&#039;t give a percent value. (0 to charge anything per person)'),
(44, 45, '&lt;b&gt;Default priority&lt;/b&gt;&lt;br/&gt;Priority to be used by default when no category default priority has been set or when using the alphabetical dish list.'),
(32, 32, '&lt;b&gt;Tables per row (Waiter)&lt;/b&gt;&lt;br/&gt;The number of tables per row displayed in the list of tables for the normal waiters.'),
(33, 33, '&lt;b&gt;Tables per row (Cashier)&lt;/b&gt;&lt;br/&gt;The number of tables per row displayed in the list of tables for the cashier users.'),
(35, 35, '&lt;b&gt;Show deleted orders.&lt;/b&gt;&lt;br/&gt;If active, shows the deleted orders in the orders list with a breaking line, instead of hiding them.'),
(36, 36, '&lt;b&gt;Show the last modified summary line.&lt;/b&gt;&lt;br/&gt;If active shows in the orders list page a line with the last modified order.'),
(37, 37, '&lt;b&gt;Service fee - Use&lt;/b&gt;&lt;br /&gt;\r\nSets if the number of people per table will be asked or not.'),
(38, 38, '&lt;b&gt;Allows unknown customers.&lt;/b&gt;&lt;br/&gt;If active, allows to type the surname of the customer in the takeaway tables.'),
(41, 42, '&lt;b&gt;Country.&lt;/b&gt;&lt;br/&gt;Select the country to be used for the currency settings.'),
(42, 43, '&lt;b&gt;Go to category after create.&lt;/b&gt;&lt;br/&gt;After creating a new order via the category interface, you go back to the same interface to insert other orders.'),
(43, 44, '&lt;b&gt;Rows per page.&lt;/b&gt;&lt;br/&gt;Sets the maximum number of table rows to be showed in a single page in the management zone.');

